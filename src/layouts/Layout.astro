---
import { MessageCircle } from 'lucide-react';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  ogType?: string;
}

const { title, description, canonical, image, ogType } = Astro.props;

const navLinks = [
  { label: "Home",      href: "/" },
  { label: "Cars",      href: "/#cars" },
  { label: "Locations", href: "/locations" },
  { label: "Service",   href: "/service" },
  { label: "Blog",      href: "/blog" },
  { label: "Contact",   href: "/contact" },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <link rel="apple-touch-icon" href="/favicon.jpg" />
    <meta name="theme-color" content="#002C5F" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-52SXCPMR');</script>
    <!-- End Google Tag Manager -->
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3RSNGNCJTG"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3RSNGNCJTG', { allow_google_signals: true, allow_ad_personalization_signals: true });
    </script>
    <!-- End GA4 -->
    <SEOHead title={title} description={description} canonical={canonical} image={image} ogType={ogType} />
  </head>
  <body class="bg-white text-[#1C1C1C] font-sans antialiased flex flex-col min-h-screen">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-52SXCPMR"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- Header -->
    <header class="fixed w-full top-0 z-50 bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100 transition-all duration-300">
      <div class="container mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-[#002C5F] font-bold text-2xl tracking-tighter hover:opacity-80 transition">
          PRAKASH<span class="font-light">HYUNDAI</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-8">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm font-medium text-gray-600 hover:text-[#002C5F] transition-colors">
              {link.label}
            </a>
          ))}
        </nav>

        <a href="https://wa.me/919052110303?text=Hi%2C%20I%20want%20to%20know%20about%20Hyundai%20cars%20in%20Nizamabad.%20%5BW-PH%5D"
          target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-2 bg-[#002C5F] text-white px-5 py-2.5 rounded-full text-sm font-bold hover:bg-[#001f42] transition-colors shadow-lg shadow-blue-900/20">
          <MessageCircle size={18} /> <span class="hidden sm:inline">WhatsApp</span>
        </a>
      </div>
    </header>

    <main class="flex-grow pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#1C1C1C] text-white py-16 mt-auto">
      <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-12 mb-12">
          <div class="col-span-2">
            <h3 class="text-xl font-bold mb-4">Prakash Hyundai</h3>
            <p class="text-gray-400 text-sm leading-relaxed max-w-sm">Authorized Dealer for Nizamabad & Districts. Providing premium Hyundai sales and service experience since 2008.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              {navLinks.map(link => (
                <li><a href={link.href} class="hover:text-white transition">{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-4">Contact</h3>
            <p class="text-gray-400 text-sm">Hyderabad Road, Dichpally</p>
            <p class="text-gray-400 text-sm">Nizamabad, Telangana 503001</p>
            <p class="text-gray-400 text-sm mt-2">+91 9052110303</p>
            <p class="text-gray-400 text-sm">+91 9052116511 (Showroom)</p>
          </div>
        </div>
        <div class="text-center text-gray-600 text-sm border-t border-gray-800 pt-8">
          &copy; {new Date().getFullYear()} Prakash Hyundai. All rights reserved.
        </div>
      </div>
    </footer>

  </body>
</html>
