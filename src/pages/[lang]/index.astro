---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/ui';
import { MessageCircle, ShieldCheck, Clock, Car, ArrowRight } from 'lucide-react';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'te' } },
    { params: { lang: 'hi' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const cars = await getCollection('cars');
const sortedCars = cars.sort((a, b) => a.data.order - b.data.order); // Show all cars
const blogs = await getCollection('blog');
const recentBlogs = blogs.slice(0, 3);
---

<Layout title="Prakash Hyundai | Authorized Hyundai Dealer in Nizamabad, Telangana" description="Prakash Hyundai is an authorized Hyundai dealership in Nizamabad, Telangana. Explore new Hyundai cars, book test drives, get expert service and genuine parts." lang={lang}>
  
  <!-- Hero Section -->
  <section class="min-h-[90vh] flex items-center bg-gradient-to-b from-[#F5F6F7] to-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-white skew-x-12 translate-x-20 hidden lg:block opacity-50"></div>
    
    <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center relative z-10 pt-10">
      <div class="space-y-8">
        <span class="inline-block px-3 py-1 bg-blue-50 text-[#002C5F] rounded-full font-bold text-xs tracking-widest uppercase border border-blue-100">Authorized Dealer • Nizamabad</span>
        <h1 class="text-5xl lg:text-7xl font-bold leading-[1.1] text-[#1C1C1C]">
            {t('hero.title')}
        </h1>
        <p class="text-xl text-gray-600 max-w-lg leading-relaxed">
            Experience the premium range of Hyundai vehicles with unmatched service and transparency.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
             <a href={`https://wa.me/919052110303?text=${t('whatsapp.msg')}`} class="flex items-center justify-center gap-2 bg-[#002C5F] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#001f42] transition-all shadow-xl shadow-blue-900/20 group">
                <MessageCircle size={20} class="group-hover:scale-110 transition-transform"/> {t('hero.cta')}
             </a>
        </div>
      </div>
      <div class="relative">
        <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl shadow-blue-900/10">
             <img src="https://www.hyundai.com/content/dam/hyundai/in/en/images/hyundai-story/hyundai-motor-india/pc/sabse-bada-deewana-pc2.jpg" class="w-full h-auto object-cover" alt="Hyundai Verna" />
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
            <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6">
                    <ShieldCheck size={24} />
                </div>
                <h3 class="text-xl font-bold mb-3">Trusted Service</h3>
                <p class="text-gray-500">Authorized service center with genuine parts.</p>
            </div>
            <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6">
                    <Clock size={24} />
                </div>
                <h3 class="text-xl font-bold mb-3">Quick Delivery</h3>
                <p class="text-gray-500">Get your dream car delivered faster.</p>
            </div>
             <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6">
                    <Car size={24} />
                </div>
                <h3 class="text-xl font-bold mb-3">Test Drives</h3>
                <p class="text-gray-500">Book a doorstep test drive today.</p>
            </div>
        </div>
    </div>
  </section>

  <!-- Cars Grid -->
  <section id="cars" class="py-24 bg-[#F5F6F7]">
    <div class="container mx-auto px-6">
        <h2 class="text-4xl font-bold text-[#1C1C1C] mb-12">{t('nav.cars')}</h2>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {sortedCars.map(car => (
                <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-300 flex flex-col h-full border border-gray-100">
                    <a href={`/${lang}/cars/${car.slug}`} class="flex-1 flex flex-col">
                        <div class="h-56 overflow-hidden relative">
                            <img src={car.data.image} alt={car.data.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                            <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-[#002C5F]">
                                {car.data.category}
                            </div>
                        </div>
                        <div class="p-6 flex-1 flex flex-col">
                            <h3 class="text-2xl font-bold mb-1 text-[#1C1C1C] group-hover:text-[#002C5F] transition-colors">{car.data.name}</h3>
                            <p class="text-sm text-gray-500 mb-6 italic">"{car.data.tagline}"</p>
                            
                            <div class="mt-auto pt-6 border-t border-gray-100">
                                <div class="flex justify-between items-center mb-3">
                                    <div>
                                        <p class="text-xs text-gray-400 uppercase font-semibold">Ex-Showroom</p>
                                        <p class="font-bold text-[#002C5F] text-lg">{car.data.price}</p>
                                    </div>
                                </div>
                                <div class="text-sm text-[#002C5F] font-medium group-hover:text-[#00AAD2] transition-colors">
                                    View Details →
                                </div>
                            </div>
                        </div>
                    </a>
                    <div class="px-6 pb-6">
                        <a href={`https://wa.me/919052110303?text=I'm interested in the price of ${car.data.name}`} 
                           class="flex items-center justify-center gap-2 w-full py-3 rounded-lg bg-blue-50 text-[#002C5F] hover:bg-[#002C5F] hover:text-white transition-colors font-medium">
                            <MessageCircle size={18} />
                            Quick Inquiry
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
  </section>

  <!-- Recent Blogs Preview -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-6">
       <div class="flex justify-between items-end mb-12">
            <h2 class="text-4xl font-bold text-[#1C1C1C]">{t('blog.title')}</h2>
            <a href={`/${lang}/blog`} class="text-[#002C5F] font-bold flex items-center gap-2 hover:gap-3 transition-all">View All <ArrowRight size={20}/></a>
       </div>
       <div class="grid md:grid-cols-3 gap-8">
          {recentBlogs.map(post => (
             <a href={`/${lang}/blog/${post.slug}`} class="group">
                <article class="p-6 rounded-2xl border border-gray-100 hover:border-blue-100 hover:shadow-lg transition-all h-full flex flex-col">
                    <div class="text-xs font-bold text-[#00AAD2] uppercase mb-2">{post.data.category}</div>
                    <h3 class="text-xl font-bold mb-3 group-hover:text-[#002C5F] transition-colors">{post.data.title}</h3>
                    <p class="text-gray-500 text-sm mb-4 line-clamp-2 flex-grow">{post.data.excerpt}</p>
                    <div class="text-xs text-gray-400 font-medium">{new Date(post.data.date).toLocaleDateString()} • {post.data.readTime}</div>
                </article>
             </a>
          ))}
       </div>
    </div>
  </section>


  <!-- Google Reviews CTA -->
  <section class="py-16 bg-gray-50 border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-[#002C5F] mb-2">What Our Customers Say</h2>
      <p class="text-gray-600 mb-8 text-lg">Trusted by Nizamabad families for Hyundai cars, genuine service and parts.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.google.com/maps/search/Prakash+Hyundai+Nizamabad"
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-white border-2 border-gray-200 text-gray-800 px-8 py-4 rounded-xl font-bold hover:border-[#002C5F] hover:bg-blue-50 transition shadow-sm">
          <svg class="w-6 h-6" viewBox="0 0 48 48"><path d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.2 7.9 3.1l5.7-5.7C34.5 6.9 29.6 5 24 5 13 5 4 14 4 25s9 20 20 20c11 0 20-9 20-20 0-1.3-.1-2.6-.4-3.9z" fill="#FFC107"/><path d="M6.3 15.4l6.6 4.8C14.6 16.2 19 13 24 13c3.1 0 5.8 1.2 7.9 3.1l5.7-5.7C34.5 7 29.6 5 24 5 16.3 5 9.7 9.2 6.3 15.4z" fill="#FF3D00"/><path d="M24 45c5.5 0 10.5-2.1 14.3-5.5l-6.6-5.6C29.7 35.8 27 37 24 37c-5.3 0-9.7-3.3-11.3-8H6.5C9.9 38.9 16.4 45 24 45z" fill="#4CAF50"/><path d="M43.6 20.1H42V20H24v8h11.3c-.8 2.2-2.2 4.1-4 5.5l6.6 5.6C37.8 37.9 44 33 44 25c0-1.3-.1-2.6-.4-3.9z" fill="#1976D2"/></svg>
          Read Our Google Reviews
        </a>
        <a href="https://www.google.com/maps/search/Prakash+Hyundai+Nizamabad"
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-[#002C5F] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#001a40] transition shadow-lg">
          Write a Review
        </a>
      </div>
    </div>
  </section>

</Layout>
