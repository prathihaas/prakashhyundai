---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/ui';
import { MapPin, Phone, Navigation, MessageCircle } from 'lucide-react';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'te' } },
    { params: { lang: 'hi' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);

const WA = "https://wa.me/919052110303";

const locations = [
  {
    name: "Prakash Hyundai - Nizamabad Main",
    address: "Hyderabad Road, Dichpally, Nizamabad, Telangana 503001",
    type: "Showroom & Service",
    phone: "9052116500",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Dichpally+Nizamabad+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Nizamabad showroom. Please share directions and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Armoor",
    address: "NH 44, Perkit, Armoor, Telangana 503224",
    type: "Sales Outlet",
    phone: "9052116509",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Armoor+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Armoor outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Bodhan",
    address: "Nizamabad Road, Bodhan, Telangana 503185",
    type: "Sales Outlet",
    phone: "9052116513",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Bodhan+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Bodhan outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Banswada",
    address: "Nizamabad Road, Banswada, Telangana",
    type: "Sales Outlet",
    phone: "9603908891",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Banswada+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Banswada outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Adilabad",
    address: "Mavla, Adilabad, Telangana",
    type: "Sales Outlet",
    phone: "9573863576",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Adilabad+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Adilabad outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Kamareddy",
    address: "Nizamabad Road, Kamareddy, Telangana",
    type: "Sales Outlet",
    phone: "7036219618",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Kamareddy+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Kamareddy outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Mancheriyal",
    address: "Mancheriyal, Telangana",
    type: "Sales Outlet",
    phone: "8886022884",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Mancheriyal+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Mancheriyal outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Nirmal",
    address: "Nirmal, Telangana",
    type: "Sales Outlet",
    phone: "9052110404",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Nirmal+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Nirmal outlet. Please share details and today's offers. [W-LOC]",
  },
  {
    name: "Prakash Hyundai - Bhainsa",
    address: "Bhainsa, Telangana",
    type: "Sales Outlet",
    phone: "8886636879",
    map_link: "https://www.google.com/maps/search/Prakash+Hyundai+Bhainsa+Telangana",
    wa_msg: "Hi Prakash Hyundai, I want to visit your Bhainsa outlet. Please share details and today's offers. [W-LOC]",
  }
];

const locSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Hyundai",
  "url": "https://www.prakashhyundai.com",
  "telephone": "+91-9052110303",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hyderabad Road, Dichpally",
    "addressLocality": "Nizamabad",
    "addressRegion": "Telangana",
    "postalCode": "503001",
    "addressCountry": "IN"
  },
  "department": locations.map(loc => ({
    "@type": "AutoDealer",
    "name": loc.name,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": loc.address,
      "addressRegion": "Telangana",
      "addressCountry": "IN"
    },
    "telephone": `+91-${loc.phone}`
  }))
};
---

<Layout
  title="Hyundai Showroom Locations in Nizamabad | Prakash Hyundai"
  description="Find Prakash Hyundai showrooms near you — Nizamabad, Armoor, Bodhan, Banswada, Kamareddy, Adilabad & more. Call for directions, test drives and best price."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(locSchema)} />

  <div class="bg-[#002C5F] text-white py-20">
    <div class="container mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t('loc.title')}</h1>
      <p class="text-blue-200 text-lg mb-6">9 showrooms across Nizamabad district — find one near you</p>
      <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I want to find the nearest showroom and get today's best price. [W-LOC-H]")}`}
        target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-6 py-3 rounded-xl transition">
        💬 WhatsApp for Nearest Showroom
      </a>
    </div>
  </div>

  <div class="container mx-auto px-6 py-16">
    <div class="grid md:grid-cols-3 gap-6">
      {locations.map(loc => (
        <div class="border border-gray-200 rounded-2xl p-6 hover:shadow-xl transition-all hover:border-blue-200 bg-white flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <div class="p-3 bg-blue-50 text-[#002C5F] rounded-lg">
              <MapPin size={22} />
            </div>
            <span class="text-xs font-bold uppercase tracking-wide bg-gray-100 text-gray-600 px-2 py-1 rounded">
              {loc.type}
            </span>
          </div>
          <h3 class="text-xl font-bold mb-2 text-[#1C1C1C]">{loc.name}</h3>
          <p class="text-gray-500 mb-5 text-sm leading-relaxed flex-1">{loc.address}</p>

          <div class="flex flex-col gap-2 mt-auto">
            <a href={`tel:${loc.phone}`}
              class="flex items-center justify-center gap-2 w-full py-3 border-2 border-gray-200 rounded-xl font-semibold text-sm hover:bg-gray-50 hover:border-[#002C5F] transition-colors text-gray-700">
              <Phone size={16} /> 📞 Call {loc.phone}
            </a>
            <a href={loc.map_link} target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-3 bg-[#002C5F] text-white rounded-xl font-semibold text-sm hover:bg-[#001f42] transition-colors">
              <Navigation size={16} /> 🗺️ Get Directions
            </a>
            <a href={`${WA}?text=${encodeURIComponent(loc.wa_msg)}`} target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-3 bg-green-600 text-white rounded-xl font-semibold text-sm hover:bg-green-700 transition-colors">
              💬 WhatsApp for Best Price
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 bg-blue-50 border border-blue-100 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold text-[#002C5F] mb-2">Can't find a showroom near you?</h2>
      <p class="text-gray-600 mb-5">WhatsApp us — we deliver test drives to your doorstep across Nizamabad district.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I need a home test drive. Please share details. [W-LOC-TD]")}`}
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-green-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-green-700 transition">
          💬 Book Home Test Drive
        </a>
        <a href="tel:9052110303"
          class="inline-flex items-center justify-center gap-2 bg-[#002C5F] text-white px-8 py-3 rounded-xl font-bold hover:bg-[#001f42] transition">
          📞 Call 9052110303
        </a>
      </div>
    </div>
  </div>

  <!-- Sticky Mobile Bottom Bar -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-gray-200 shadow-2xl p-3 flex gap-3 sm:hidden">
    <a href="tel:9052110303"
      class="flex-1 flex items-center justify-center gap-2 bg-[#002C5F] text-white py-3 rounded-xl font-bold text-sm">
      📞 Call
    </a>
    <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I want to find the nearest showroom. [W-LOC-BAR]")}`}
      target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 bg-green-600 text-white py-3 px-5 rounded-xl font-bold text-sm" style="flex:2">
      💬 WhatsApp Us
    </a>
  </div>

  <div class="pb-20 sm:pb-0"></div>

</Layout>
