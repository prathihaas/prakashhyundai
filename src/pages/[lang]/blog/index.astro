---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/ui';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'te' } },
    { params: { lang: 'hi' } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Hyundai Car Tips, Comparisons & Guides | Prakash Hyundai Nizamabad" description="Car buying guides, Hyundai model comparisons, and local driving tips from Prakash Hyundai — authorized Hyundai dealer in Nizamabad, Telangana." lang={lang}>

  <div class="bg-[#F5F6F7] py-24 pt-32">
    <div class="container mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-bold text-[#1C1C1C] mb-4">Car Guides & Tips</h1>
      <p class="text-gray-600 max-w-2xl text-lg">Honest Hyundai reviews, buying guides, and local driving advice from the Prakash Hyundai team in Nizamabad.</p>
    </div>
  </div>

  <div class="container mx-auto px-6 py-20">
    <div class="grid md:grid-cols-3 gap-8">
      {sortedPosts.map(post => (
        <a href={`/${lang}/blog/${post.slug}`} class="group flex flex-col">
          <article class="rounded-2xl border border-gray-100 hover:border-blue-100 hover:shadow-xl transition-all h-full bg-white flex flex-col overflow-hidden">
            <div class="aspect-video bg-gray-100 overflow-hidden">
              {post.data.featured_image
                ? <img src={post.data.featured_image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                : <div class="w-full h-full flex items-center justify-center bg-[#002C5F]/5"><span class="text-[#002C5F]/20 text-5xl font-bold">H</span></div>
              }
            </div>
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-bold text-[#00AAD2] uppercase tracking-widest bg-[#00AAD2]/10 px-2 py-0.5 rounded-full">{post.data.category}</span>
                {post.data.readTime && <span class="text-xs text-gray-400">{post.data.readTime}</span>}
              </div>
              <h3 class="text-xl font-bold mb-3 group-hover:text-[#002C5F] transition-colors leading-snug flex-grow">{post.data.title}</h3>
              <p class="text-gray-500 text-sm line-clamp-2 mb-5 leading-relaxed">{post.data.excerpt}</p>
              <div class="pt-4 border-t border-gray-100 text-xs text-gray-400 font-medium">
                {post.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</Layout>
