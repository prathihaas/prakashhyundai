    <!-- Services List -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-3">Services Available at Prakash Hyundai</h2>
      <p class="text-gray-600 mb-6">Our full-facility service center handles everything from routine maintenance to accident repairs and insurance claims.</p>
