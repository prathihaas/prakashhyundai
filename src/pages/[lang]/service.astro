    <!-- Location -->
    <div class="grid lg:grid-cols-2 gap-12 mb-16">
      <div>
        <h2 class="text-3xl font-bold text-[#1C1C1C] mb-6">Service Center Location & Hours</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-[#002C5F]/10 rounded-xl flex-shrink-0">
              <span class="text-[#002C5F] text-xl">📍</span>
            </div>
