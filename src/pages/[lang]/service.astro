        {[
          "Engine oil & filter change",
          "Air filter & cabin filter replacement",
          "Brake pad & disc inspection/replacement",
          "AC service & refrigerant recharge",
          "Tyre rotation & wheel balancing",
          "Wheel alignment",
          "Battery check & replacement",
          "Spark plug replacement",
          "Coolant flush & refill",
          "Brake fluid replacement",
          "GDS computerized diagnostics",
          "Transmission fluid service",
          "Suspension & shock absorber check",
          "Denting & painting (authorized body shop)",
          "Accident repair & insurance processing",
          "Genuine Hyundai spare parts",
          "Annual Maintenance Contract (AMC)",
          "Windshield replacement",
          "Door & trim panel repair",
          "Pre-purchase inspection",
        ].map(service => (
          <div class="flex items-center gap-2 bg-[#F5F6F7] rounded-xl p-3 text-sm font-medium text-gray-700">
            <span class="text-[#002C5F] flex-shrink-0 font-bold">●</span> {service}
          </div>
        ))}
      </div>
    </div>

    <!-- Hyundai Models -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-3">Hyundai Cars We Service</h2>
      <p class="text-gray-600 mb-6">Authorized to service all Hyundai passenger cars sold in India.</p>
      <div class="flex flex-wrap gap-3">
        {[
          "Hyundai Creta", "Hyundai Venue", "Hyundai i20",
          "Hyundai Grand i10 Nios", "Hyundai Verna", "Hyundai Alcazar",
          "Hyundai Exter", "Hyundai Tucson", "Hyundai Ioniq 5",
