              <td class="p-4 text-sm font-bold text-[#002C5F]">Comprehensive Service</td>
            </tr>
            <tr class="border-b border-gray-100 bg-gray-50">
              <td class="p-4 font-semibold">60,000 km / 60 months</td>
              <td class="p-4 text-sm text-gray-600">All 30k items + timing belt (if applicable), transmission fluid, full chassis inspection</td>
              <td class="p-4 text-sm font-bold text-[#002C5F]">Major Service (Quotation)</td>
            </tr>
          </tbody>
        </table>
