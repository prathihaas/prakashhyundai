---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return ['en', 'te', 'hi'].map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Prakash Hyundai — Authorized Hyundai Service Center, Nizamabad",
  "url": "https://www.prakashhyundai.com/en/service",
  "telephone": "+91-9052110303",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hyderabad Road, Dichpally",
    "addressLocality": "Nizamabad",
    "addressRegion": "Telangana",
    "postalCode": "503001",
    "addressCountry": "IN"
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "09:00",
    "closes": "19:30"
  }],
  "brand": { "@type": "Brand", "name": "Hyundai" },
  "parentOrganization": { "@type": "AutoDealer", "name": "Prakash Hyundai", "url": "https://www.prakashhyundai.com" }
};
---

<Layout title="Hyundai Service Center Nizamabad | Prakash Hyundai" description="Authorized Hyundai car service center in Nizamabad. Periodic maintenance, genuine Hyundai parts, AMC plans, denting & painting. Book service at Prakash Hyundai." lang={lang}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <div class="container mx-auto px-6 py-20">

    <!-- Hero -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#002C5F]/10 text-[#002C5F] mb-4">
        <span class="text-xs font-bold uppercase tracking-wider">Authorized Hyundai Service Center</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-[#1C1C1C] mb-4 leading-tight">Authorized Hyundai Service Center <br class="hidden md:block">in Nizamabad</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-4">Prakash Hyundai is Nizamabad's authorized Hyundai car service center — genuine parts, factory-trained technicians, transparent pricing, and a service experience that matches what you'd expect from a premium brand.</p>
      <p class="text-gray-500 mb-8">Hyderabad Road, Dichpally, Nizamabad — serving Nizamabad, Kamareddy, Nirmal and surrounding districts.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/919052110303?text=Hi%2C%20I%20want%20to%20book%20a%20Hyundai%20car%20service.%20%5BW-PH%5D" target="_blank"
           class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-7 py-3 rounded-xl font-bold text-lg hover:bg-green-600 transition shadow-lg">
          Book Service via WhatsApp
        </a>
        <a href="tel:+919052110303"
           class="inline-flex items-center justify-center gap-2 bg-[#002C5F] text-white px-7 py-3 rounded-xl font-bold text-lg hover:bg-[#001f42] transition shadow-lg">
          Call: 9052110303
        </a>
      </div>
    </div>

    <!-- Why Authorized Service -->
    <div class="bg-[#F5F6F7] rounded-3xl p-10 mb-16">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-3">Why Authorized Hyundai Service?</h2>
      <p class="text-gray-600 mb-8 max-w-3xl">Hyundai cars come with sophisticated electronics, ADAS features, and complex fuel injection systems that require specialized tools and genuine parts. Here's why Prakash Hyundai is the right choice for every service visit.</p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Genuine Hyundai Parts</h3>
          <p class="text-gray-600 text-sm">Factory-sourced components with Hyundai India authentication. Genuine parts preserve engine performance, fuel efficiency, and safety system integrity.</p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Hyundai-Certified Technicians</h3>
          <p class="text-gray-600 text-sm">Our service team is trained and certified by Hyundai Motor India. They work with GDS diagnostic tools on every model from the i10 Nios to Alcazar.</p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Warranty Protection</h3>
          <p class="text-gray-600 text-sm">Hyundai's 3-year warranty (and extended warranty options) remain valid only with authorized service. Don't risk losing your warranty to an unauthorized shop.</p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Digital Service Records</h3>
          <p class="text-gray-600 text-sm">Every service logged in Hyundai India's centralized system — boosts resale value and gives the next owner confidence in the car's maintenance history.</p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Transparent Pricing</h3>
          <p class="text-gray-600 text-sm">Itemized invoice with Hyundai MRP parts pricing and standard labour rates. You approve every item before work begins — no hidden charges.</p>
        </div>
        <div class="bg-white rounded-2xl p-6">
          <div class="w-10 h-10 bg-[#002C5F]/10 rounded-xl flex items-center justify-center mb-3">
            <span class="text-[#002C5F] font-bold text-lg">✓</span>
          </div>
          <h3 class="font-bold text-[#1C1C1C] mb-2">Complimentary Car Wash</h3>
          <p class="text-gray-600 text-sm">Every vehicle gets a complimentary exterior wash and interior vacuum after service — your Hyundai goes home cleaner than it arrived.</p>
        </div>
      </div>
    </div>

    <!-- Service Packages -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-3">Hyundai Service Packages</h2>
      <p class="text-gray-600 mb-8">We offer three service packages to match every need and budget — from a quick periodic service to a full comprehensive inspection.</p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="border-2 border-gray-200 rounded-3xl p-8 hover:border-[#002C5F] transition">
          <h3 class="text-xl font-bold text-[#1C1C1C] mb-2">Basic Service</h3>
          <p class="text-3xl font-bold text-[#002C5F] mb-1">₹2,499<span class="text-sm font-normal text-gray-500">+</span></p>
          <p class="text-gray-500 text-sm mb-6">Starting price for small cars (i10 Nios, Grand i10). Sedans & SUVs higher.</p>
          <ul class="space-y-3 text-sm text-gray-600">
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Engine oil change (Hyundai approved)</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Oil filter replacement</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Air filter inspection</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Tyre pressure & rotation check</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Brake inspection</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Complimentary car wash</li>
          </ul>
        </div>
        <div class="border-2 border-[#002C5F] rounded-3xl p-8 bg-[#002C5F] text-white">
          <div class="inline-block bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full mb-3">Most Popular</div>
          <h3 class="text-xl font-bold mb-2">Standard Service</h3>
          <p class="text-3xl font-bold text-white mb-1">₹4,499<span class="text-sm font-normal text-white/70">+</span></p>
          <p class="text-white/60 text-sm mb-6">Starting price for i20, Venue, Verna. Creta & Alcazar higher.</p>
          <ul class="space-y-3 text-sm text-white/80">
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> All Basic Service items</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> Air filter replacement</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> Cabin (pollen) filter check</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> Battery health check</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> AC performance check</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> Suspension & steering check</li>
            <li class="flex items-center gap-2"><span class="text-white font-bold">✓</span> 25-point inspection</li>
          </ul>
        </div>
        <div class="border-2 border-gray-200 rounded-3xl p-8 hover:border-[#002C5F] transition">
          <h3 class="text-xl font-bold text-[#1C1C1C] mb-2">Comprehensive Service</h3>
          <p class="text-3xl font-bold text-[#002C5F] mb-1">₹8,999<span class="text-sm font-normal text-gray-500">+</span></p>
          <p class="text-gray-500 text-sm mb-6">Full service for all models. Recommended every 30,000 km or 3 years.</p>
          <ul class="space-y-3 text-sm text-gray-600">
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> All Standard Service items</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Spark plug replacement</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Coolant flush & refill</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> Brake fluid replacement</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> GDS computerized diagnostics</li>
            <li class="flex items-center gap-2"><span class="text-[#002C5F] font-bold">✓</span> 50-point full inspection</li>
          </ul>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-4 text-center">* All prices include labour. Parts billed separately at Hyundai India MRP. Obtain exact quote at service booking.</p>
    </div>

    <!-- Service Schedule -->
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-3">Hyundai Car Service Schedule</h2>
      <p class="text-gray-600 mb-6">Hyundai recommends servicing every <strong>10,000 km or 12 months</strong>, whichever comes first. Following this schedule preserves engine life, fuel efficiency, and warranty coverage.</p>
      <div class="overflow-x-auto rounded-2xl border border-gray-200">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-[#002C5F] text-white">
              <th class="p-4 text-left text-sm font-bold">Service Interval</th>
              <th class="p-4 text-left text-sm font-bold">Key Jobs</th>
              <th class="p-4 text-left text-sm font-bold">Recommended Package</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="p-4 font-semibold">10,000 km / 12 months</td>
              <td class="p-4 text-sm text-gray-600">Engine oil & filter, tyre rotation, brake check, visual inspection</td>
              <td class="p-4 text-sm font-bold text-[#002C5F]">Basic Service</td>
            </tr>
            <tr class="border-b border-gray-100 bg-gray-50">
