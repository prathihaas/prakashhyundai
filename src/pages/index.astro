---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { MessageCircle, ShieldCheck, Clock, Car, ArrowRight } from 'lucide-react';

const cars = await getCollection('cars');
const sortedCars = cars.sort((a, b) => a.data.order - b.data.order);
const blogs = await getCollection('blog');
const recentBlogs = blogs
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const WA    = "https://wa.me/919052110303";
const PHONE = "tel:+919052110303";

const hyRatingSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  "name": "Prakash Hyundai",
  "url": "https://www.prakashhyundai.com",
  "telephone": "+91-9052110303",
  "logo": "https://www.prakashhyundai.com/logo.png",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Hyderabad Road, Dichpally",
    "addressLocality": "Nizamabad",
    "addressRegion": "Telangana",
    "postalCode": "503001",
    "addressCountry": "IN"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.7",
    "reviewCount": "2915",
    "bestRating": "5",
    "worstRating": "1"
  },
  "department": [
    {
      "@type": "AutoDealer",
      "name": "Prakash Hyundai — Nizamabad Main",
      "telephone": "+91-9052116511",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Hyderabad Road, Dichpally",
        "addressLocality": "Nizamabad",
        "addressRegion": "Telangana",
        "postalCode": "503001",
        "addressCountry": "IN"
      }
    },
    {
      "@type": "AutoDealer",
      "name": "Prakash Hyundai — Armoor",
      "telephone": "+91-9052116509",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "NH 44, Perkit",
        "addressLocality": "Armoor",
        "addressRegion": "Telangana",
        "addressCountry": "IN"
      }
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which Hyundai cars are available in Nizamabad?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Hyundai Nizamabad stocks the full Hyundai lineup — Creta, Venue, Exter, i20, Grand i10 Nios, Verna, Aura, Alcazar, i20 N-Line, Creta N-Line and Ioniq 5. All models available for test drive at our Dichpally showroom." }
    },
    {
      "@type": "Question",
      "name": "What is the on-road price of Hyundai Creta in Nizamabad?",
      "acceptedAnswer": { "@type": "Answer", "text": "The Hyundai Creta on-road price in Nizamabad ranges from approximately ₹12.5 lakh (base petrol) to ₹22 lakh (top diesel variant). Contact Prakash Hyundai at 9052110303 for exact current pricing and offers." }
    },
    {
      "@type": "Question",
      "name": "Does Prakash Hyundai offer home test drives?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes! Prakash Hyundai offers free doorstep test drives across Nizamabad city and surrounding areas. WhatsApp 9052110303 to book your home test drive today." }
    },
    {
      "@type": "Question",
      "name": "What finance options are available for Hyundai cars in Nizamabad?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Hyundai offers car loans through SBI, HDFC, Axis, and other banks. EMI starts from ₹8,500/month on select models. Zero down payment schemes available. Call 9052110303 for your EMI quote." }
    },
    {
      "@type": "Question",
      "name": "Where is Prakash Hyundai located in Nizamabad?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our main showroom is at Hyderabad Road, Dichpally, Nizamabad, Telangana 503001. We also have outlets in Armoor, Bodhan, Banswada, Kamareddy, Adilabad, Mancheriyal, Nirmal and Bhainsa." }
    },
    {
      "@type": "Question",
      "name": "How many Hyundai showrooms does Prakash Hyundai have?",
      "acceptedAnswer": { "@type": "Answer", "text": "Prakash Hyundai operates 9 showrooms across Nizamabad district — Nizamabad main, Armoor, Bodhan, Banswada, Kamareddy, Adilabad, Mancheriyal, Nirmal and Bhainsa." }
    }
  ]
};
---

<Layout
  title="Hyundai Showroom Nizamabad | Best Price, Test Drive & EMI | Prakash Hyundai"
  description="Authorized Hyundai dealer in Nizamabad. Best price on Creta, Venue, Exter, i20 & more. Free home test drive. EMI from ₹8,500/month. Call 9052110303."
  canonical="https://www.prakashhyundai.com/"
>

  <script type="application/ld+json" set:html={JSON.stringify(hyRatingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="min-h-[90vh] flex items-center bg-gradient-to-b from-[#F5F6F7] to-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-white skew-x-12 translate-x-20 hidden lg:block opacity-50"></div>
    <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-16 items-center relative z-10 pt-10">
      <div class="space-y-7">
        <span class="inline-block px-3 py-1 bg-blue-50 text-[#002C5F] rounded-full font-bold text-xs tracking-widest uppercase border border-blue-100">✅ Authorized Dealer · 9 Showrooms · Nizamabad</span>
        <h1 class="text-4xl lg:text-6xl font-bold leading-[1.1] text-[#1C1C1C]">
          Hyundai Showroom Nizamabad — Best Price & Free Test Drive
        </h1>
        <p class="text-lg text-gray-600 max-w-lg leading-relaxed">
          Get today's best ex-showroom price on Creta, Venue, Exter, i20 and all Hyundai models. Free home test drive. Easy EMI. Trusted by 2,915+ Nizamabad families.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I want today's best price on a Hyundai car in Nizamabad. [W-HP]")}`}
            target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 bg-green-600 text-white px-7 py-4 rounded-xl font-bold text-lg hover:bg-green-700 transition shadow-lg shadow-green-100">
            💬 Get Best Price on WhatsApp
          </a>
          <a href={PHONE}
            class="flex items-center justify-center gap-2 bg-[#002C5F] text-white px-7 py-4 rounded-xl font-bold text-lg hover:bg-[#001f42] transition shadow-lg shadow-blue-900/20">
            📞 Call 9052110303
          </a>
        </div>
        <div class="inline-flex items-center gap-3 bg-blue-50 border border-blue-100 rounded-xl px-5 py-3">
          <span class="text-2xl">💰</span>
          <div>
            <p class="font-bold text-[#002C5F] text-sm">Hyundai Exter EMI from ₹8,500/month</p>
            <p class="text-xs text-gray-500">Zero down payment · Instant approval via SBI, HDFC, Axis</p>
          </div>
          <a href={`${WA}?text=${encodeURIComponent("Hi, I want to check EMI eligibility for a Hyundai car in Nizamabad. [W-EMI]")}`}
            target="_blank" rel="noopener noreferrer"
            class="text-xs text-[#002C5F] font-bold hover:underline whitespace-nowrap">Check EMI →</a>
        </div>
      </div>
      <div class="relative">
        <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl shadow-blue-900/10">
          <img
            src="https://www.hyundai.com/content/dam/hyundai/in/en/images/home/banner/venue-homepage-des-banner.jpg"
            class="w-full h-auto object-cover"
            alt="Hyundai Showroom Nizamabad — Best Price on Creta, Venue, Exter"
          />
        </div>
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl p-4 z-20 flex items-center gap-3">
          <div>
            <div class="text-yellow-400 text-sm">★★★★★</div>
            <p class="font-black text-[#002C5F] text-xl">4.7</p>
          </div>
          <div>
            <p class="font-bold text-gray-800 text-sm">2,915+ Reviews</p>
            <p class="text-xs text-gray-500">Nizamabad's #1 Hyundai Dealer</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="py-6 bg-[#002C5F]">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-6 text-white text-sm font-semibold">
        {["✅ Authorized Hyundai Dealer", "🏠 Free Home Test Drive", "💳 Zero Down Payment EMI", "🔧 Genuine Parts & Service", "📋 Easy Finance — All Banks", "🏆 4.7★ / 2915+ Google Reviews"].map(b => (
          <span class="flex items-center gap-1">{b}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6"><ShieldCheck size={24} /></div>
          <h3 class="text-xl font-bold mb-3">Trusted Authorized Service</h3>
          <p class="text-gray-500">Hyundai-certified technicians, genuine parts, and full warranty support at all our locations.</p>
        </div>
        <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6"><Clock size={24} /></div>
          <h3 class="text-xl font-bold mb-3">Fast Delivery & Easy Finance</h3>
          <p class="text-gray-500">Loan approval in minutes. Drive home your new Hyundai faster with zero paperwork hassle.</p>
        </div>
        <div class="p-8 rounded-2xl bg-gray-50 border border-transparent hover:border-gray-200 transition-all">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-[#002C5F] mb-6"><Car size={24} /></div>
          <h3 class="text-xl font-bold mb-3">Free Home Test Drive</h3>
          <p class="text-gray-500">Test drive any Hyundai at your doorstep — Nizamabad, Armoor, Bodhan, Banswada and beyond.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cars Grid -->
  <section id="cars" class="py-20 bg-[#F5F6F7]">
    <div class="container mx-auto px-6">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
        <div>
          <h2 class="text-4xl font-bold text-[#1C1C1C]">Hyundai Cars in Nizamabad</h2>
          <p class="text-gray-500 mt-2">All models · Best ex-showroom price guaranteed</p>
        </div>
        <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, please share price list for all Hyundai cars in Nizamabad. [W-HP-PL]")}`}
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 text-white px-5 py-3 rounded-xl font-bold text-sm hover:bg-green-700 transition whitespace-nowrap">
          💬 Get Full Price List
        </a>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {sortedCars.map(car => (
          <div class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-300 flex flex-col h-full border border-gray-100">
            <a href={`/cars/${car.slug}`} class="flex-1 flex flex-col">
              <div class="h-52 overflow-hidden relative">
                <img src={car.data.image} alt={`Hyundai ${car.data.name} price in Nizamabad`}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-2 py-1 rounded-full text-xs font-bold uppercase tracking-wider text-[#002C5F]">
                  {car.data.category}
                </div>
              </div>
              <div class="p-5 flex-1 flex flex-col">
                <h3 class="text-xl font-bold mb-1 text-[#1C1C1C] group-hover:text-[#002C5F] transition-colors">Hyundai {car.data.name}</h3>
                <p class="text-xs text-gray-400 uppercase font-semibold mt-auto pt-4">Ex-Showroom Nizamabad</p>
                <p class="font-bold text-[#002C5F] text-lg">{car.data.price}</p>
              </div>
            </a>
            <div class="px-5 pb-5 flex flex-col gap-2">
              <a href={`${WA}?text=${encodeURIComponent(`Hi Prakash Hyundai, I am interested in the Hyundai ${car.data.name}. Please share today's best price and EMI options in Nizamabad. [W-HP-CAR]`)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-green-600 text-white hover:bg-green-700 transition font-bold text-sm">
                💬 Get Best Price
              </a>
              <a href={`${WA}?text=${encodeURIComponent(`Hi Prakash Hyundai, I want a free test drive for the Hyundai ${car.data.name} in Nizamabad. [W-HP-TD]`)}`}
                target="_blank" rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full py-2 rounded-xl border-2 border-gray-200 text-gray-700 hover:border-[#002C5F] hover:text-[#002C5F] transition font-semibold text-sm">
                🏎️ Book Test Drive
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Blogs -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6">
      <div class="flex justify-between items-end mb-10">
        <h2 class="text-3xl font-bold text-[#1C1C1C]">Car Guides & Tips</h2>
        <a href="/blog" class="text-[#002C5F] font-bold flex items-center gap-2 hover:gap-3 transition-all text-sm">View All <ArrowRight size={18}/></a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {recentBlogs.map(post => (
          <a href={`/blog/${post.slug}`} class="group">
            <article class="p-6 rounded-2xl border border-gray-100 hover:border-blue-100 hover:shadow-lg transition-all h-full flex flex-col">
              <div class="text-xs font-bold text-[#00AAD2] uppercase mb-2">{post.data.category}</div>
              <h3 class="text-lg font-bold mb-2 group-hover:text-[#002C5F] transition-colors leading-snug">{post.data.title}</h3>
              <p class="text-gray-500 text-sm mb-4 line-clamp-2 flex-grow">{post.data.excerpt}</p>
              <div class="text-xs text-gray-400 font-medium">{new Date(post.data.date).toLocaleDateString()} · {post.data.readTime}</div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-[#F5F6F7]">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl font-bold text-[#1C1C1C] mb-10 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          { q: "Which Hyundai cars are available in Nizamabad?", a: "Prakash Hyundai stocks the full lineup — Creta, Venue, Exter, i20, Grand i10 Nios, Verna, Aura, Alcazar, i20 N-Line, Creta N-Line and Ioniq 5. All models available for test drive." },
          { q: "What is the on-road price of Hyundai Creta in Nizamabad?", a: "Hyundai Creta on-road price in Nizamabad ranges from ~₹12.5 lakh (base petrol) to ~₹22 lakh (top diesel). Call 9052110303 for exact current price and offers." },
          { q: "Does Prakash Hyundai offer home test drives?", a: "Yes! We offer free doorstep test drives across Nizamabad, Armoor, Bodhan, Banswada and surrounding areas. WhatsApp 9052110303 to book." },
          { q: "What EMI options are available on Hyundai cars in Nizamabad?", a: "EMI available through SBI, HDFC, Axis and other banks. Zero down payment on select models. EMI starts from ₹8,500/month. Call 9052110303 for your quote." },
          { q: "How many showrooms does Prakash Hyundai have?", a: "We have 9 showrooms across Nizamabad district — Nizamabad main, Armoor, Bodhan, Banswada, Kamareddy, Adilabad, Mancheriyal, Nirmal and Bhainsa." }
        ].map(item => (
          <details class="bg-white rounded-xl border border-gray-200 overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer font-bold text-gray-800 hover:text-[#002C5F] transition-colors list-none">
              <span>{item.q}</span>
              <span class="text-[#002C5F] text-xl ml-4 flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <div class="px-5 pb-5 text-gray-600 text-sm leading-relaxed border-t border-gray-100 pt-4">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-black text-[#002C5F] mb-2">What Our Customers Say</h2>
        <div class="flex items-center justify-center gap-3 mb-1">
          <span class="text-yellow-400 text-2xl">★★★★★</span>
          <span class="text-4xl font-black text-[#002C5F]">4.7</span>
          <span class="text-gray-500 text-base">/ 5 &nbsp;·&nbsp; <strong class="text-gray-700">2,915+ reviews</strong></span>
        </div>
      </div>
      <div class="grid sm:grid-cols-2 gap-5 mb-8">
        {[
          { initial: "B", name: "Bodige", text: "Prakash Hyundai showroom is the best in Nizamabad for 15+ years. Quick services, free test drives, certified mechanics, friendly staff, on-time delivery and car wash. Very satisfied!" },
          { initial: "S", name: "Sreenaiah", text: "Excellent experience with the team. Very happy with Prakash Hyundai treatment in the showroom. Best Hyundai dealer in Nizamabad." },
          { initial: "S", name: "Sree", text: "Nice behaviour of the staff. Really love the way they treated us. The entire buying experience was smooth and pleasant." },
          { initial: "V", name: "Venkat", text: "Good service and prompt response. The service team is attentive and gets the job done quickly. Highly recommend!" },
        ].map(r => (
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
            <div class="text-yellow-400 text-lg mb-2">★★★★★</div>
            <p class="text-gray-700 text-sm leading-relaxed mb-4">"{r.text}"</p>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-[#002C5F] text-white text-xs flex items-center justify-center font-bold">{r.initial}</div>
              <span class="text-sm font-semibold text-gray-700">{r.name}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://www.google.com/maps/search/Prakash+Hyundai+Nizamabad" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-white border-2 border-gray-200 text-gray-800 px-8 py-4 rounded-xl font-bold hover:border-[#002C5F] hover:bg-blue-50 transition shadow-sm text-sm">
          📖 Read All Google Reviews
        </a>
        <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I want to book a test drive and get today's best price. [W-HP-REV]")}`}
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#002C5F] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#001a40] transition shadow-lg text-sm">
          💬 Book Test Drive on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile Bottom Bar -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-gray-200 shadow-2xl p-3 flex gap-3 sm:hidden">
    <a href={PHONE} class="flex-1 flex items-center justify-center gap-2 bg-[#002C5F] text-white py-3 rounded-xl font-bold text-sm">📞 Call</a>
    <a href={`${WA}?text=${encodeURIComponent("Hi Prakash Hyundai, I want today's best price on a Hyundai car in Nizamabad. [W-HP-BAR]")}`}
      target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 bg-green-600 text-white py-3 px-5 rounded-xl font-bold text-sm" style="flex:2">
      💬 Get Best Price
    </a>
  </div>
  <div class="pb-20 sm:pb-0"></div>

</Layout>
