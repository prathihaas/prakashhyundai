---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { MessageCircle, ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
  const cars = await getCollection('cars');
  return cars.map(car => ({ params: { slug: car.slug }, props: { car } }));
}

const { car } = Astro.props;
const { Content } = await car.render();

const carDescription = `Buy ${car.data.name} in Nizamabad from Prakash Hyundai. ${car.data.tagline}. Ex-showroom price ${car.data.price}. Book a test drive or get the best quote today — call +91 9052116511.`;
const priceMatch = car.data.price.match(/[\d.]+/);
const numericPrice = priceMatch ? Math.round(parseFloat(priceMatch[0]) * 100000) : 0;

const carSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `Hyundai ${car.data.name}`,
  "brand": { "@type": "Brand", "name": "Hyundai" },
  "image": car.data.image,
  "description": carDescription,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "INR",
    "price": numericPrice,
    "priceValidUntil": "2026-12-31",
    "availability": "https://schema.org/InStock",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@type": "AutoDealer", "name": "Prakash Hyundai", "url": "https://www.prakashhyundai.com" }
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.prakashhyundai.com/" },
    { "@type": "ListItem", "position": 2, "name": "Cars", "item": "https://www.prakashhyundai.com/#cars" },
    { "@type": "ListItem", "position": 3, "name": `Hyundai ${car.data.name}`, "item": `https://www.prakashhyundai.com/cars/${car.slug}` }
  ]
};
---

<Layout title={`Hyundai ${car.data.name} Price in Nizamabad | Prakash Hyundai`} description={carDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(carSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="min-h-screen bg-gradient-to-b from-[#F5F6F7] to-white">
    <div class="container mx-auto px-6 pt-8">
      <a href="/#cars" class="inline-flex items-center gap-2 text-[#002C5F] hover:text-[#00AAD2] font-medium transition-colors">
        <ArrowLeft size={20} /> All Cars
      </a>
    </div>

    <section class="container mx-auto px-6 py-12">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <div class="inline-block px-4 py-2 bg-blue-50 text-[#002C5F] rounded-full font-bold text-sm uppercase tracking-wider border border-blue-100">
            {car.data.category}
          </div>
          <h1 class="text-5xl lg:text-6xl font-bold text-[#1C1C1C] leading-tight">Hyundai {car.data.name}</h1>
          <p class="text-2xl text-gray-600 italic">"{car.data.tagline}"</p>
          <div class="flex items-baseline gap-2">
            <span class="text-sm text-gray-500 uppercase font-semibold">Starting From (Ex-Showroom Nizamabad)</span>
          </div>
          <p class="text-3xl font-bold text-[#002C5F]">{car.data.price}</p>
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <a href={`https://wa.me/919052110303?text=${encodeURIComponent(`Hi Prakash Hyundai, I want today's best price for Hyundai ${car.data.name} in Nizamabad with EMI options. [W-CAR]`)}`}
              target="_blank" rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-green-600 text-white px-7 py-4 rounded-xl font-bold hover:bg-green-700 transition shadow-lg">
              💬 Get Best Price on WhatsApp
            </a>
            <a href="tel:+919052110303"
              class="flex items-center justify-center gap-2 bg-[#002C5F] text-white px-7 py-4 rounded-xl font-bold hover:bg-[#001f42] transition shadow-lg">
              📞 Call 9052110303
            </a>
          </div>
          <a href={`https://wa.me/919052110303?text=${encodeURIComponent(`Hi Prakash Hyundai, I want a free home test drive for Hyundai ${car.data.name}. [W-CAR-TD]`)}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border-2 border-gray-200 text-gray-700 hover:border-[#002C5F] hover:text-[#002C5F] px-6 py-3 rounded-xl font-semibold transition text-sm">
            🏎️ Book Free Home Test Drive
          </a>
        </div>
        <div class="relative">
          <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl">
            <img src={car.data.image} alt={`Hyundai ${car.data.name} Nizamabad`} class="w-full h-auto object-cover" />
          </div>
        </div>
      </div>
    </section>

    {car.data.features && car.data.features.length > 0 && (
      <section class="container mx-auto px-6 py-12">
        <div class="bg-white rounded-3xl p-8 shadow-lg border border-gray-100">
          <h2 class="text-3xl font-bold text-[#1C1C1C] mb-8">Key Features</h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {car.data.features.map((feature) => (
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 bg-[#00AAD2] rounded-full mt-2 flex-shrink-0"></div>
                <p class="text-gray-700 leading-relaxed">{feature}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="container mx-auto px-6 py-12 pb-20">
      <div class="bg-white rounded-3xl p-8 lg:p-12 shadow-lg border border-gray-100">
        <div class="prose prose-lg prose-blue max-w-none prose-headings:font-bold prose-headings:text-[#002C5F] prose-a:text-[#00AAD2] prose-ul:text-gray-700 prose-p:text-gray-700">
          <Content />
        </div>
      </div>
    </section>

    <section class="container mx-auto px-6 pb-20">
      <div class="bg-gradient-to-r from-[#002C5F] to-[#00AAD2] rounded-3xl p-12 text-center text-white">
        <h2 class="text-3xl font-bold mb-4">Interested in Hyundai {car.data.name}?</h2>
        <p class="text-xl mb-8 text-blue-100">Contact us today for a test drive and best price quote!</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`https://wa.me/919052110303?text=${encodeURIComponent(`Hi Prakash Hyundai, I want to book a test drive for Hyundai ${car.data.name}. [W-CAR-CTA]`)}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white text-[#002C5F] px-8 py-4 rounded-xl font-bold hover:bg-gray-100 transition-all shadow-xl">
            <MessageCircle size={20} /> Request Test Drive
          </a>
          <a href="tel:+919052110303"
            class="inline-flex items-center gap-2 bg-green-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-green-700 transition-all shadow-xl">
            📞 Call 9052110303
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- Sticky Mobile Bar -->
  <div class="fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-gray-200 shadow-2xl p-3 flex gap-3 sm:hidden">
    <a href="tel:+919052110303" class="flex-1 flex items-center justify-center gap-2 bg-[#002C5F] text-white py-3 rounded-xl font-bold text-sm">📞 Call</a>
    <a href={`https://wa.me/919052110303?text=${encodeURIComponent(`Hi Prakash Hyundai, I want best price for Hyundai ${car.data.name} in Nizamabad. [W-CAR-BAR]`)}`}
      target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 bg-green-600 text-white py-3 px-5 rounded-xl font-bold text-sm" style="flex:2">
      💬 Get Best Price
    </a>
  </div>
  <div class="pb-20 sm:pb-0"></div>
</Layout>
